---
import Layout from '../layouts/Layout.astro';
---

<Layout category="all">
  <main id="app" data-category="all">
    <header class="hero">
      <div class="hero__container">
        <h1 class="hero__title" data-i18n="heroTitle">Styles for slides</h1>
        <p class="hero__subtitle">
          <span id="style-count">0</span> <span data-i18n="heroSub">curated YAML prompts for NotebookLM</span>
        </p>
      </div>
    </header>

    <section class="grid-section">
      <div id="styles-grid" class="bento-grid"></div>
      
      <div id="pagination" class="pagination" hidden>
        <button id="load-more" class="load-more-btn" data-i18n="loadMore">Explore More Styles</button>
      </div>

      <p id="empty-state" class="empty-state" hidden data-i18n="emptyState">
        No styles with preview images available yet. Check back soon.
      </p>
    </section>
  </main>
</Layout>
