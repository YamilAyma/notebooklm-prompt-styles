---
import Layout from '../layouts/Layout.astro';
import YouTubeLink from '../components/YouTubeLink.astro';
import PortfolioIcon from '~icons/carbon/portfolio';
import HelpIcon from '~icons/carbon/help';
---

<Layout category="landing">
  <main id="landing">
    <!-- Hero Section -->
    <section class="landing-hero">
      <div class="hero-bg-grid">
        <div class="hero-bg-grid__track">
          <!-- Column 1 -->
          <div class="hero-bg-grid__col">
            <img src="/preview/editorial_essence/editorial_essence_1.png" alt="" />
            <img src="/preview/geometric_mono/geometric_mono_1.png" alt="" />
            <img src="/preview/architectural_cobalt/architectural_cobalt_1.png" alt="" />
            <img src="/preview/artisan_rust/artisan_rust_1.png" alt="" />
            <img src="/preview/creative_classroom/creative_classroom_1.png" alt="" />
          </div>
          <!-- Column 2 -->
          <div class="hero-bg-grid__col hero-bg-grid__col--reverse">
            <img src="/preview/executive_report/executive_report_1.png" alt="" />
            <img src="/preview/architectural_mono/architectural_mono_1.png" alt="" />
            <img src="/preview/creative_spark/creative_spark_1.png" alt="" />
            <img src="/preview/cobalt_editorial/cobalt_editorial_1.png" alt="" />
            <img src="/preview/botanical_journal/botanical_journal_1.png" alt="" />
          </div>
          <!-- Column 3 -->
          <div class="hero-bg-grid__col">
            <img src="/preview/creative_workshop/creative_workshop_1.png" alt="" />
            <img src="/preview/ensign_corporate/ensign_corporate_1.png" alt="" />
            <img src="/preview/editorial_essence/editorial_essence_2.png" alt="" />
            <img src="/preview/geometric_mono/geometric_mono_2.png" alt="" />
            <img src="/preview/architectural_cobalt/architectural_cobalt_2.png" alt="" />
          </div>
          <!-- Column 4 -->
          <div class="hero-bg-grid__col hero-bg-grid__col--reverse">
            <img src="/preview/artisan_rust/artisan_rust_2.png" alt="" />
            <img src="/preview/creative_spark/creative_spark_2.png" alt="" />
            <img src="/preview/cobalt_editorial/cobalt_editorial_2.png" alt="" />
            <img src="/preview/creative_classroom/creative_classroom_2.png" alt="" />
            <img src="/preview/ensign_corporate/ensign_corporate_2.png" alt="" />
          </div>
        </div>
      </div>

      <div class="landing-hero__container">
        <div class="hero-content-box hero-entrance">
          <div class="hero-content-inner">
            <h1 class="landing-hero__title" data-i18n="landingHeroTitle">Elevate Your NotebookLM Slides</h1>
            <p class="landing-hero__subtitle" data-i18n="landingHeroSub">The ultimate collection of professional YAML styles for high-impact presentations.</p>
            <div class="landing-hero__actions">
              <a href="/styles" class="btn btn--primary">
                <PortfolioIcon class="btn__icon" />
                <span data-i18n="landingCtaBtn">Explore Gallery</span>
              </a>
              <a href="#how-it-works" class="btn btn--secondary">
                <HelpIcon class="btn__icon" />
                <span data-i18n="landingHowItWorks">How it Works</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <style>
      .landing-hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: var(--color-bg);
      }

      .hero-bg-grid {
        position: absolute;
        inset: 0;
        z-index: 1;
        opacity: 0.9;
        transform: scale(1.02);
        mask-image: linear-gradient(
          to bottom,
          transparent 0%,
          black 15%,
          black 85%,
          transparent 100%
        );
        -webkit-mask-image: linear-gradient(
          to bottom,
          transparent 0%,
          black 15%,
          black 85%,
          transparent 100%
        );
      }

      .hero-bg-grid__track {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-xs);
        height: 100%;
      }

      .hero-bg-grid__col {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
        animation: scroll-up 120s linear infinite;
      }

      .hero-bg-grid__col--reverse {
        animation: scroll-down 120s linear infinite;
      }

      .hero-bg-grid img {
        width: 100%;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 0;
        background: #eee;
        border: 1px solid rgba(255,255,255,0.1);
      }

      @keyframes scroll-up {
        0% { transform: translateY(0); }
        100% { transform: translateY(-50%); }
      }

      @keyframes scroll-down {
        0% { transform: translateY(-50%); }
        100% { transform: translateY(0); }
      }

      .landing-hero__container {
        position: relative;
        z-index: 10;
        width: 100%;
        max-width: 720px;
        padding: 0 var(--space-lg);
      }

      .hero-entrance {
        animation: heroEntrance 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
      }

      @keyframes heroEntrance {
        from {
          opacity: 0;
          transform: translateY(30px);
          filter: blur(15px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
          filter: blur(0);
        }
      }

      .hero-content-box {
        background: #fff;
        padding: var(--space-3xl) var(--space-2xl);
        border-radius: 10px;
        position: relative;
        box-shadow: 
          inset 0 0 100px rgba(255,255,255,1),
          inset 0 0 40px rgba(0,0,0,0.02),
          0 0 0 20px #fff; 
        border: 1px solid rgba(0,0,0,0.05);
      }

      .hero-content-inner {
        position: relative;
        z-index: 2;
      }

      .landing-hero__title {
        font-size: clamp(2.25rem, 7vw, 3.75rem);
        line-height: 0.95;
        margin-bottom: var(--space-lg);
        color: #2b2b2b;
        font-weight: 900;
        letter-spacing: -0.06em;
        text-shadow: 0 1px 1px rgba(0,0,0,0.1);
      }

      .landing-hero__subtitle {
        font-size: 1.125rem;
        color: #666;
        margin-bottom: var(--space-2xl);
        max-width: 540px;
        margin-left: auto;
        margin-right: auto;
        font-weight: 500;
        line-height: 1.45;
      }

      .landing-hero__actions {
        display: flex;
        gap: var(--space-md);
        justify-content: center;
        align-items: center;
      }

      .btn__icon {
        width: 20px;
        height: 20px;
        margin-right: 8px;
        flex-shrink: 0;
      }

      .btn--primary {
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      }

      @media (max-width: 768px) {
        .landing-hero {
          height: auto;
          padding: var(--space-4xl) 0;
          min-height: 80vh;
        }
        .hero-bg-grid__track {
          grid-template-columns: repeat(2, 1fr);
          gap: 4px;
        }
        .hero-content-box {
          padding: var(--space-2xl) var(--space-lg);
          box-shadow: 
            inset 0 0 30px rgba(0,0,0,0.05),
            0 0 0 15px #fff;
        }
        .landing-hero__title {
          font-size: 2.2rem;
          letter-spacing: -0.04em;
        }
        .landing-hero__subtitle {
          font-size: 1.1rem;
          margin-bottom: var(--space-xl);
        }
      }

      @media (max-width: 480px) {
        .landing-hero {
          padding: var(--space-3xl) 0;
        }
        .hero-content-box {
          padding: var(--space-xl) var(--space-md);
          box-shadow: 
            inset 0 0 20px rgba(0,0,0,0.05),
            0 0 0 10px #fff;
        }
        .landing-hero__title {
          font-size: 1.8rem;
        }
        .landing-hero__actions {
          flex-direction: column;
          gap: var(--space-sm);
        }
        .landing-hero__actions .btn {
          width: 100%;
          justify-content: center;
        }
      }
      .how-it-works-video {
        margin-top: var(--space-3xl);
      }
    </style>

    <!-- Examples Section -->
    <section class="landing-section">
      <div class="landing-section__container">
        <h2 class="landing-section__title" data-i18n="landingExamplesTitle">Curated Examples</h2>
        <div id="featured-grid" class="bento-grid">
          <!-- Featured cards will be injected by app.js -->
        </div>
        <div class="landing-section__footer">
          <a href="/styles" class="btn btn--outline" data-i18n="loadMore">View All Styles</a>
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section id="how-it-works" class="landing-section landing-section--alt">
      <div class="landing-section__container">
        <h2 class="landing-section__title" data-i18n="landingHowItWorks">How it Works</h2>
        <div class="how-it-works-grid">
          <div class="how-card">
            <div class="how-card__number">01</div>
            <h3 class="how-card__title" data-i18n="step1Title">Choose a Style</h3>
            <p class="how-card__desc" data-i18n="step1Desc">Explore our collection and copy the YAML code of your favorite style.</p>
          </div>
          <div class="how-card">
            <div class="how-card__number">02</div>
            <h3 class="how-card__title" data-i18n="step4Title">Paste Prompt</h3>
            <p class="how-card__desc" data-i18n="step4Desc">Paste the YAML code you copied into the custom instructions box in NotebookLM Studio.</p>
          </div>
          <div class="how-card">
            <div class="how-card__number">03</div>
            <h3 class="how-card__title" data-i18n="step5Title">Generate</h3>
            <p class="how-card__desc" data-i18n="step5Desc">Click 'Generate' and watch NotebookLM transform your sources into a stunning presentation.</p>
          </div>
        </div>

        <YouTubeLink 
          class="how-it-works-video" 
          href="https://youtu.be/x3vWKEqKBpY"
          resultHref="/samples/demo_notebooklm_prompt_styles.pdf"
        />
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="landing-section">
      <div class="landing-section__container landing-section__container--narrow">
        <h2 class="landing-section__title" data-i18n="landingFaqTitle">Questions? We have answers</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary class="faq-item__question" data-i18n="faqQ1">What are these YAML prompts?</summary>
            <div class="faq-item__answer" data-i18n="faqA1">They are configuration blocks that tell NotebookLM exactly how to style your slides, from colors to typography.</div>
          </details>
          <details class="faq-item">
            <summary class="faq-item__question" data-i18n="faqQ2">Do I need to pay for this?</summary>
            <div class="faq-item__answer" data-i18n="faqA2">No, this is a community-driven open-source project. All prompts are free to use.</div>
          </details>
          <details class="faq-item">
            <summary class="faq-item__question" data-i18n="faqQ3">Can I contribute my own styles?</summary>
            <div class="faq-item__answer" data-i18n="faqA3">Yes! Check our Contribution Guide on GitHub to learn how to add your own designs.</div>
          </details>
        </div>
      </div>
    </section>

    <!-- Video CTA Section -->
    <section class="cta-video-section">
      <div class="video-bg">
        <video autoplay muted loop playsinline class="video-bg__content">
          <source src="/videos/presentation-notebooklm-prompt-styles.mp4" type="video/mp4">
        </video>
      </div>
      <div class="video-overlay"></div>
      <div class="cta-video-section__content">
        <h2 class="cta-video-section__title" data-i18n="landingVideoCtaTitle">Ready to Transform Your Workflow?</h2>
        <p class="cta-video-section__subtitle" data-i18n="landingVideoCtaSub">Supercharge your slide deck generation with our expert prompts.</p>
        <a href="/styles" class="btn btn--primary btn--large" data-i18n="landingVideoCtaBtn">Get Started Now</a>
      </div>
    </section>
  </main>
</Layout>
